# Convex
# (These are auto-populated when you run `npx convex dev`)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Clerk
# Get from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# OpenRouter
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Report Generation API
# Used to protect the /api/generate-report endpoint (for n8n webhooks)
REPORT_API_KEY=

# MOTTO API (for Notion integration from Convex)
# Set in Convex env: npx convex env set MOTTO_API_KEY <key>
MOTTO_API_KEY=

# ngrok (for sharing demos)
# Get domain from: https://dashboard.ngrok.com/domains
NGROK_DOMAIN=
